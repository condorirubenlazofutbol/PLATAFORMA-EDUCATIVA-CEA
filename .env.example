# ════════════════════════════════════════════
#  EduConnect Pro – Variables de Entorno
#  Copia este archivo a .env y completa los valores
# ════════════════════════════════════════════

# ── Base de Datos PostgreSQL ──────────────────
# Opción 1: URL completa (Render/Railway/Neon)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/educonnect_pro

# Opción 2: Variables individuales (Desarrollo local)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=educonnect_ruben

# ── Seguridad JWT ─────────────────────────────
# Clave secreta para firmar los tokens.
# Genera una segura con: openssl rand -hex 32
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA

# Algoritmo de firma del token
ALGORITHM=HS256

# Tiempo de expiración del token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Inteligencia Artificial (Opcional) ────────
# Configurar SOLO si quieres activar la IA real.
# Si no se configura, el módulo de Planes IA funciona en modo demo.

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Google Gemini (alternativa)
GEMINI_API_KEY=AIza...

# ── Railway / Producción ──────────────────────
# Railway inyecta estas variables automáticamente.
# No las configures manualmente si usas Railway.
RAILWAY_STATIC_URL=
PORT=8000

# ── Entorno ───────────────────────────────────
# Cambia a 'production' al hacer deploy
ENVIRONMENT=development
